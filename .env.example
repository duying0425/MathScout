MATHSCOUT_ENV=development
DATABASE_URL=sqlite+pysqlite:///./.data/mathscout_dev.db
RAW_STORAGE_DIR=.data/raw
TEXT_STORAGE_DIR=.data/text
COOKIE_STORAGE_DIR=.data/cookies
DEFAULT_USER_AGENT=MathScout/0.1 (+local research crawler)
CRAWL_DEFAULT_DELAY_SECONDS=3
CRAWL_MAX_CONCURRENCY=4
AI_PROVIDER=rule
DEEPSEEK_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=https://api.deepseek.com
OPENAI_COMPATIBLE_MODEL=deepseek-chat
OPENAI_COMPATIBLE_TIMEOUT_SECONDS=90
AI_MAX_TEXT_CHARS=12000

# 文档转换 / OCR（扫描版 PDF、图片）。留空则不启用 OCR，扫描件标记为 needs_ocr。
# 端点形如 https://<resource>.cognitiveservices.azure.com/
# 若填了 KEY，将用 AzureKeyCredential；否则用 Azure 默认凭据（az login / 托管身份等）。
AZURE_DOC_INTEL_ENDPOINT=
AZURE_DOC_INTEL_KEY=

# 附件下载：链接发现阶段识别并入队 PDF/Office 附件
DOWNLOAD_ATTACHMENTS=true
